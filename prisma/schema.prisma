// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TAXPAYER
  ADMIN
}

enum TaxType {
  PERSONAL_INCOME
  COMPANY_INCOME
  VAT
  WITHHOLDING
  CAPITAL_GAINS
}

enum ReturnStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  QUERIED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  tin           String?   @unique       // Tax Identification Number
  email         String    @unique
  password      String
  role          Role      @default(TAXPAYER)
  firstName     String
  lastName      String
  phone         String?
  address       String?
  state         String?
  lga           String?                 // Local Government Area
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  taxReturns    TaxReturn[]
  payments      Payment[]
  notifications Notification[]
  auditLogs     AuditLog[]    @relation("AuditUser")
  reviewedBy    AuditLog[]    @relation("AuditAdmin")

  @@map("users")
}

model TaxReturn {
  id              String       @id @default(cuid())
  userId          String
  taxYear         Int
  taxType         TaxType
  status          ReturnStatus @default(DRAFT)

  // Income details
  grossIncome     Float        @default(0)
  otherIncome     Float        @default(0)
  totalIncome     Float        @default(0)

  // Deductions
  personalRelief  Float        @default(0)
  pensionRelief   Float        @default(0)
  otherDeductions Float        @default(0)
  totalDeductions Float        @default(0)

  // Tax computation
  taxableIncome   Float        @default(0)
  taxLiability    Float        @default(0)
  taxPaid         Float        @default(0)  // PAYE already deducted
  taxDue          Float        @default(0)

  // Admin fields
  adminRemarks    String?
  reviewedBy      String?
  reviewedAt      DateTime?
  submittedAt     DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id])
  payment         Payment?
  certificate     Certificate?

  @@unique([userId, taxYear, taxType])
  @@map("tax_returns")
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  taxReturnId   String        @unique
  amount        Float
  reference     String        @unique  // Remita/Paystack ref
  status        PaymentStatus @default(PENDING)
  channel       String?       // "remita" | "paystack" | "bank"
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  taxReturn     TaxReturn     @relation(fields: [taxReturnId], references: [id])

  @@map("payments")
}

model Certificate {
  id            String    @id @default(cuid())
  taxReturnId   String    @unique
  certificateNo String    @unique
  issuedAt      DateTime  @default(now())
  validUntil    DateTime

  taxReturn     TaxReturn @relation(fields: [taxReturnId], references: [id])

  @@map("certificates")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  adminId   String?
  action    String
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation("AuditUser", fields: [userId], references: [id])
  admin     User?    @relation("AuditAdmin", fields: [adminId], references: [id])

  @@map("audit_logs")
}
